{
  "_instructions": {
    "purpose": "GLP-1 / GIP-GLP coverage pathway data model for a simple professional coverage-prep page. The page is not a payer determination, a clinical guideline, or member-specific benefit verification.",
    "core_user_workflow": [
      "User selects insurance and plan type.",
      "Application displays exact payer_id + plan_type_id policy row only; never infer across plans.",
      "Each drug displays one or more indication/pathway rows.",
      "Each pathway has a single status: covered_no_prior_authorization, covered_with_conditions_no_authorization, covered_with_authorization, covered_with_authorization_and_prior_trials, or not_covered.",
      "User checks one or more relevant pathways/indications.",
      "Application generates value/evidence fields, relevant Epic search terms, ICD-10 OR blocks, and a concise bottom summary. No patient letter. No extra persuasion layer."
    ],
    "status_rules": {
      "covered_no_prior_authorization": "Use only when the payer/formulary source explicitly indicates the agent is covered and no authorization/step criteria are listed. Criteria may be empty; if diagnosis consistency is still expected, list it under clinical_context rather than formal criteria.",
      "covered_with_conditions_no_authorization": "Use when no authorization is listed, but coverage requires documented diagnosis/lab/indication criteria such as T2D, HbA1c threshold, BMI threshold, OSA, or MASH stage.",
      "covered_with_authorization": "Use when prior authorization/coverage review is required and the pathway depends on diagnosis/lab/indication criteria but no explicit prior therapy/step trial is required.",
      "covered_with_authorization_and_prior_trials": "Use when authorization is required and the payer also requires prior medication trial, preferred-agent failure, lifestyle program duration, PAP/CPAP trial/status, or other prior therapy evidence.",
      "not_covered": "Use only when source explicitly excludes the drug/indication. Keep visible but visually separate; do not mix with positive coverage pathways."
    },
    "research_requirements_for_each_policy": [
      "Every real payer row must include payer_id, plan_type_id, policy_name, verification_status, source_name, source_url, effective_date, retrieved_date, and agents[].",
      "Every agent must include drug, ingredient, class, and pathways[].",
      "Every pathway must include id, indication, status, criteria, prior_trials, target_values_summary, notes, source_refs, and evidence_tier.",
      "criteria and prior_trials must reference criteria_library IDs using all_of / any_of. Keep logic shallow where possible. If payer text is complex, create a named criterion with a clear label and target_value.",
      "criteria_library entries should include label, target_value, value_prompt, acceptable_evidence, icd10_codes, epic_terms, and optional notes. This is what makes the Epic block and value fields relevant instead of noisy.",
      "ICD-10 codes should be included only when relevant to the criterion. Separate codes with OR in the app output. Include many codes only when they help retrieve chart evidence. Mark uncertain/candidate code groups in notes for human coding verification.",
      "Research universe rows are scaffolds only. Do not convert them to payer coverage without exact payer evidence."
    ],
    "coverage_universe_to_consider_in_deep_research": [
      "Type 2 diabetes glycemic control and cardiometabolic risk reduction",
      "Chronic weight management: adult BMI >=30 or BMI >=27 with weight-related comorbidity",
      "Obstructive sleep apnea with obesity, especially moderate-to-severe OSA and AHI/REI documentation",
      "Cardiovascular risk reduction in established CVD with overweight/obesity where labeled/policy-recognized",
      "CKD with type 2 diabetes where labeled/policy-recognized",
      "MASH/MASLD/fatty liver: especially noncirrhotic MASH with moderate-to-advanced fibrosis F2-F3 where labeled/policy-recognized",
      "Pediatric T2D and adolescent obesity where product labeling/policy supports it",
      "Explicit exclusions: cosmetic weight loss, off-label weight loss for diabetes-only products, compounded/unapproved products, noncovered benefit categories"
    ]
  },
  "schema_version": "3.0-status-workbench",
  "created": "2026-06-13",
  "verification_notice": "Demonstration/research scaffold. Replace sample payer rows with exact payer/PBM policy evidence before clinical use.",
  "status_definitions": {
    "covered_no_prior_authorization": {
      "label": "Covered \u2014 no authorization listed",
      "short_label": "Covered",
      "color": "green"
    },
    "covered_with_conditions_no_authorization": {
      "label": "Covered if criteria documented \u2014 no authorization listed",
      "short_label": "Covered with criteria",
      "color": "green"
    },
    "covered_with_authorization": {
      "label": "Covered with authorization",
      "short_label": "Covered with authorization",
      "color": "yellow"
    },
    "covered_with_authorization_and_prior_trials": {
      "label": "Covered with authorization + prior trial/step",
      "short_label": "Authorization + prior trial",
      "color": "orange"
    },
    "not_covered": {
      "label": "Not covered",
      "short_label": "Not covered",
      "color": "red"
    }
  },
