  "status_definitions": {
    "covered_no_prior_authorization": "Covered; no authorization listed in this policy row.",
    "covered_with_conditions_no_authorization": "Covered without authorization if specific indication criteria are documented.",
    "covered_with_authorization": "Covered with authorization if criteria are documented.",
    "covered_with_authorization_and_prior_trials": "Covered with authorization if criteria and prior trial/step therapy requirements are documented.",
    "not_covered": "Not covered under this policy row. Show separately; do not mix with covered pathways."
  },
